      <div id="gss" class="accordion-content max-h-0 bg-white rounded-xl shadow px-6">
        <ul class="py-4 space-y-2">
          <li>https://motionpictures.monday.com/boards/1735781645SB Around the World</a></li>
          <li>https://motionpictures.monday.com/boards/1901785736SB Cases</a></li>
          <li>https://motionpictures.monday.com/boards/1736947920CJEU Overview</a></li>
          <li>https://motionpictures.monday.com/boards/2073211338AI & Copyright Case Law</a></li>
          <li>https://motionpictures.monday.com/boards/1959576984Member Action Required (GSS)</a></li>
        </ul>
      </div>

    </div>
  </div>

<script>
  lucide.createIcons();

  const buttons = document.querySelectorAll('.accordion-btn');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.target);

      document.querySelectorAll('.accordion-content').forEach(c => {
        if (c !== target) c.style.maxHeight = null;
      });

      document.querySelectorAll('.chevron').forEach(c => c.classList.remove('rotate'));

      if (!target.style.maxHeight) {
        target.style.maxHeight = target.scrollHeight + "px";
        btn.querySelector('.chevron').classList.add('rotate');
      } else {
        target.style.maxHeight = null;
      }
    });
  });
</script>

</body>
</html>
